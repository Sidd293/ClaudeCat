    "build-image": "docker build -t claudecat/workspace:latest -f docker/workspace.Dockerfile ."
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "ora": "^8.0.1"
  },
  "engines": {
    "node": ">=18"
  },
