{
  "name": "claudecat-poc",
  "version": "0.1.0",
  "description": "ClaudeCat POC — a sleeping cat orchestrates Claude Code workers in Docker containers to build your projects.",
  "type": "module",
  "bin": {
    "claudecat": "./src/orchestrator.js"
  },
  "scripts": {
    "start": "node src/server.js",
